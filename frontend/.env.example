# Google OAuth Client ID (public — safe to expose in frontend)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API URL — set this on Cloudflare to your Render backend URL
# Leave empty in local dev (Vite proxy handles it automatically)
VITE_API_BASE_URL=https://your-backend.onrender.com/api/v1
